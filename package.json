{
  "name": "earth-3d-dashboard",
  "version": "1.0.0",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "start": "lite-server",
    "lint": "eslint src tests --ext .js",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "test": "vitest run",
    "test:watch": "vitest",
    "verify": "npm run lint && npm run format:check && npm run test",
    "data:validate": "node scripts/data/validate-layers.mjs",
    "data:build": "node scripts/data/build-layers.mjs",
    "data:refresh": "npm run data:validate && npm run data:build"
  },
