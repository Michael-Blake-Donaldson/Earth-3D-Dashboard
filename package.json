  "dependencies": {
    "@babylonjs/core": "^7.35.1",
    "@babylonjs/gui": "^7.35.1",
    "@babylonjs/loaders": "^7.35.1",
    "babylonjs": "^7.35.1"
  },
  "devDependencies": {
    "eslint": "^9.24.0",
    "prettier": "^3.5.3",
    "vitest": "^3.1.1"
  }
}
